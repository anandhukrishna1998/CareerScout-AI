NODE_ENV=development
APP_ENV=development

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost/api

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost
JWT_SECRET=change-me-super-long-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
UPLOAD_MAX_MB=10

# AI / LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
AI_ENGINE_URL=http://ai-engine:8010

# Database / Cache
POSTGRES_USER=careerscout
POSTGRES_PASSWORD=careerscout
POSTGRES_DB=careerscout
DATABASE_URL=postgresql+asyncpg://careerscout:careerscout@postgres:5432/careerscout
REDIS_URL=redis://redis:6379/0

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=replace-me
SENDGRID_API_KEY=replace-me
EMAIL_FROM=no-reply@careerscout.ai

# Worker / Scheduler
SCRAPE_REGIONS=fr
SCRAPE_JOB_FAMILIES=ai,data,ml,software
SCRAPE_CONCURRENCY=5
SCRAPE_HOURS_OLD=24
SCRAPE_SEARCH_TERM=AI OR Data OR Machine Learning OR Software
SCRAPE_LOCATION=France
SCRAPE_SOURCES=linkedin_jobs,google_jobs,welcome_to_the_jungle,hellowork,indeed,apec,france_travail,monster,free_work,malt,remoteok,weworkremotely,greenhouse,lever,company_career_pages
SCRAPE_BACKENDS_LINKEDIN_JOBS=jobspy,scrapy,playwright
SCRAPE_BACKENDS_GOOGLE_JOBS=httpx,jobspy,scrapy,playwright
SCRAPE_BACKENDS_WELCOME_TO_THE_JUNGLE=httpx,scrapy,playwright
SCRAPE_BACKENDS_HELLOWORK=httpx,scrapy,playwright
SCRAPE_BACKENDS_INDEED=jobspy,scrapy,playwright
SCRAPE_BACKENDS_APEC=httpx,scrapy,playwright
SCRAPE_BACKENDS_FRANCE_TRAVAIL=httpx,scrapy,playwright
SCRAPE_BACKENDS_MONSTER=jobspy,scrapy,playwright
SCRAPE_BACKENDS_FREE_WORK=httpx,scrapy,playwright
SCRAPE_BACKENDS_MALT=httpx,scrapy,playwright
SCRAPE_BACKENDS_REMOTEOK=httpx,scrapy,playwright
SCRAPE_BACKENDS_WEWORKREMOTELY=httpx,scrapy,playwright
SCRAPE_BACKENDS_GREENHOUSE=httpx,scrapy,playwright
SCRAPE_BACKENDS_LEVER=httpx,scrapy,playwright
SCRAPE_BACKENDS_COMPANY_CAREER_PAGES=httpx,scrapy,playwright

